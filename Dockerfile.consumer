FROM golang:1.25-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY consumer/ ./consumer/
# clickhouse-go 是纯 Go 驱动，不再需要 CGO/sqlite-libs
RUN CGO_ENABLED=0 go build -o consumer ./consumer/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=builder /build/consumer .
EXPOSE 8080
CMD ["./consumer"]
