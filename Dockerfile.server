FROM golang:1.25-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY server/ ./server/
COPY web/ ./web/
RUN CGO_ENABLED=0 go build -o server ./server/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=builder /build/server .
COPY --from=builder /build/web ./web/
EXPOSE 8080 6060
CMD ["./server"]
